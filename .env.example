# Server
SERVER_PORT=8000
DEBUG=false

# Database (SQLite default, or set SQL_DSN for MySQL/PostgreSQL)
SQLITE_PATH=uniapi.db
SQL_DSN=

# Session
SESSION_SECRET=
COOKIE_MAX_AGE_HOURS=168

# Token
TOKEN_KEY_PREFIX=sk-

# Rate limits
API_RATE_LIMIT=480
RELAY_RATE_LIMIT=480

# Provider API keys (set per provider as needed)
DEEPSEEK_API_KEY=
GLM_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=

# Budget & Redis (leave BUDGET_REDIS_URL empty, set BUDGET_ENABLED=false to disable)
BUDGET_REDIS_URL=
BUDGET_ENABLED=false
DEFAULT_MONTHLY_BUDGET=800.0
