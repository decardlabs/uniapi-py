# Server
SERVER_PORT=8000
DEBUG=false

# Database (SQLite default, or set SQL_DSN for MySQL/PostgreSQL)
# 务必使用绝对路径避免因工作目录不同导致数据错乱
SQLITE_PATH=uniapi.db
SQL_DSN=

# Session（空值则每次启动随机生成，所有会话会失效）
SESSION_SECRET=
# SESSION_SECRET=建议用 openssl rand -hex 32 生成固定值
COOKIE_MAX_AGE_HOURS=168

# Token
TOKEN_KEY_PREFIX=sk-

# Rate limits（次/分钟）
API_RATE_LIMIT=480
RELAY_RATE_LIMIT=480

# Provider API keys（建议留空，在渠道中单独设置 Key）
DEEPSEEK_API_KEY=
GLM_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=

# Budget & Redis（没有 Redis 请禁用）
BUDGET_REDIS_URL=
BUDGET_ENABLED=false
DEFAULT_MONTHLY_BUDGET=800.0
