# Server
SERVER_PORT=8000
DEBUG=false

# Database (SQLite default, or set SQL_DSN for MySQL/PostgreSQL)
SQLITE_PATH=uniapi.db
SQL_DSN=

# Session
SESSION_SECRET=
COOKIE_MAX_AGE_HOURS=168
ENABLE_COOKIE_SECURE=false

# Token
TOKEN_KEY_PREFIX=sk-

# Rate limits
GLOBAL_API_RATE_LIMIT=480
GLOBAL_RELAY_RATE_LIMIT=480

# Relay
RELAY_TIMEOUT=300
RELAY_PROXY=

# DeepSeek (default key for channel testing)
DEEPSEEK_API_KEY=
